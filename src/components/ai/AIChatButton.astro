---
import { Icon } from 'astro-icon/components';
// Floating launcher for the AI assistant. Sits bottom-LEFT so it never collides
// with the WhatsApp (bottom-10) / scroll-to-top (bottom-28) stack on the right.
---

<div
  id="ai-chat-btn"
  class="fixed left-6 bottom-10 z-50 opacity-0 translate-y-4 pointer-events-none transition-all duration-300"
>
  <button
    aria-label="Ask Josh AI"
    class="group relative flex items-center gap-2 h-14 pl-4 pr-5 rounded-full bg-gradient-to-br from-blue-600 to-indigo-600 hover:from-blue-500 hover:to-indigo-500 active:scale-95 text-white shadow-lg shadow-blue-600/30 transition-all duration-200"
  >
    <span class="relative flex h-6 w-6 items-center justify-center">
      <Icon name="lucide:sparkles" class="w-5 h-5" />
      <span class="absolute -right-1 -top-1 h-2 w-2 rounded-full bg-emerald-400 ring-2 ring-blue-600 group-hover:ring-blue-500"></span>
    </span>
    <span class="text-sm font-semibold">
      <span class="i18n-en">Ask AI</span>
      <span class="i18n-id">Tanya AI</span>
    </span>
  </button>
</div>
