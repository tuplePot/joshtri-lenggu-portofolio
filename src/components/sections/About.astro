---
import { Icon } from 'astro-icon/components';
import Heading from '@/components/ui/Heading.astro';
import Button from '@/components/ui/Button.astro';

const codingSince   = 2020;
const yearsOfCoding = new Date().getFullYear() - codingSince;

const stats = [
  { value: `${yearsOfCoding}+`, label: 'Years Coding',    accent: 'text-white'     },
  { value: '1.5+',              label: 'Years Pro Exp',   accent: 'text-blue-400'  },
  { value: '10+',               label: 'Projects Built',  accent: 'text-white'     },
  { value: '15+',               label: 'Technologies',    accent: 'text-blue-400'  },
];

const facts = [
  { icon: 'lucide:map-pin',       label: 'North Jakarta, Indonesia', color: 'text-blue-400'   },
  { icon: 'lucide:graduation-cap', label: 'Computer Science',         color: 'text-yellow-400' },
  { icon: 'lucide:zap',           label: 'Coding since 2020',         color: 'text-purple-400' },
  { icon: 'lucide:briefcase',     label: 'Open to opportunities',     color: 'text-green-400'  },
];
---

<section id="about" class="relative py-32">
  <div class="max-w-7xl mx-auto px-6 sm:px-10">

    <!-- Section label -->
    <div class="mb-16 about-label">
      <span class="inline-flex items-center gap-1.5 text-xs font-semibold tracking-widest text-blue-400 uppercase">
        <span class="w-4 h-px bg-blue-400/60"></span>
        About Me
        <span class="w-4 h-px bg-blue-400/60"></span>
      </span>
    </div>

    <!-- Two-column grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">

      <!-- LEFT: Text content -->
      <div class="about-text">
        <Heading level="h2" class="text-white mb-6 leading-snug">
          A bit about <br />
          <span class="text-blue-400">who I am</span>
        </Heading>

        <p class="text-lg text-gray-400 leading-relaxed mb-4">
          I'm <span class="text-white font-medium">Joshtri Lenggu</span> — a Full-Stack Developer
          from North Jakarta, Indonesia. I've been building for the web since 2020, working on
          government platforms, internal tools, and personal projects across the full stack.
        </p>

        <p class="text-lg text-gray-400 leading-relaxed mb-8">
          What drives me is simple: I like writing code that
          <em class="text-white not-italic font-medium">actually works</em>.
          Not just passes a test — but holds up under real usage. Clean architecture,
          sensible APIs, and UIs that don't need a manual. That's the standard I aim for.
        </p>

        <!-- Key facts -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-10">
          {facts.map(({ icon, label, color }) => (
            <div class="flex items-center gap-3 px-4 py-3 rounded-xl border border-white/8 bg-white/4 hover:bg-white/6 transition-colors duration-200">
              <Icon name={icon} class={`w-5 h-5 shrink-0 ${color}`} />
              <span class="text-base text-gray-300">{label}</span>
            </div>
          ))}
        </div>

        <Button href="/cv.pdf" variant="outline" download>
          <Icon name="lucide:download" class="w-4 h-4" />
          Download CV
        </Button>
      </div>

      <!-- RIGHT: Terminal card -->
      <div class="about-terminal relative">

        <!-- Decorative glow behind card -->
        <div class="absolute -inset-10 bg-blue-600/5 rounded-full blur-3xl pointer-events-none"></div>

        <div class="relative rounded-2xl border border-white/10 bg-black/60 backdrop-blur-sm overflow-hidden">

          <!-- Terminal title bar -->
          <div class="flex items-center gap-2 px-4 py-3 border-b border-white/8 bg-white/4">
            <span class="w-3 h-3 rounded-full bg-red-500/80"></span>
            <span class="w-3 h-3 rounded-full bg-yellow-500/80"></span>
            <span class="w-3 h-3 rounded-full bg-green-500/80"></span>
            <span class="ml-3 text-xs text-gray-500 font-mono">~/joshtri — zsh</span>
          </div>

          <!-- Terminal body -->
          <div class="p-6 font-mono text-sm leading-7 select-none">

            <!-- Command line -->
            <p>
              <span class="text-green-400">joshtri@dev</span><span class="text-white/30">:</span><span class="text-blue-400">~</span>
              <span class="text-white/40"> $ </span>
              <span class="text-white">whoami</span>
            </p>

            <!-- Output block -->
            <div class="mt-3">
              <p>
                <span class="text-violet-400">const</span>
                <span class="text-blue-300"> me</span>
                <span class="text-white/40"> = </span>
                <span class="text-white/50">&#123;</span>
              </p>
              <p class="pl-6">
                <span class="text-sky-300">name</span><span class="text-white/40">:</span>
                <span class="text-white/40">     </span>
                <span class="text-emerald-400">"Joshtri Lenggu"</span><span class="text-white/30">,</span>
              </p>
              <p class="pl-6">
                <span class="text-sky-300">role</span><span class="text-white/40">:</span>
                <span class="text-white/40">     </span>
                <span class="text-emerald-400">"Full-Stack Developer"</span><span class="text-white/30">,</span>
              </p>
              <p class="pl-6">
                <span class="text-sky-300">location</span><span class="text-white/40">:</span>
                <span class="text-white/40"> </span>
                <span class="text-emerald-400">"Jakarta, 🇮🇩"</span><span class="text-white/30">,</span>
              </p>
              <p class="pl-6">
                <span class="text-sky-300">stack</span><span class="text-white/40">:</span>
                <span class="text-white/40">    </span>
                <span class="text-white/50">[</span>
                <span class="text-emerald-400">"Web"</span><span class="text-white/30">, </span>
                <span class="text-emerald-400">"API"</span><span class="text-white/30">, </span>
                <span class="text-emerald-400">"UI"</span>
                <span class="text-white/50">]</span><span class="text-white/30">,</span>
              </p>
              <p class="pl-6">
                <span class="text-sky-300">available</span><span class="text-white/40">:</span>
                <span class="text-white/40"> </span>
                <span class="text-orange-400">true</span><span class="text-white/30">,</span>
              </p>
              <p><span class="text-white/50">&#125;</span></p>
            </div>

            <!-- Next prompt with blinking cursor -->
            <div class="mt-4 flex items-center">
              <span class="text-green-400">joshtri@dev</span><span class="text-white/30">:</span><span class="text-blue-400">~</span>
              <span class="text-white/40"> $ </span>
              <span class="terminal-cursor"></span>
            </div>
          </div>

          <!-- Bottom glow accent -->
          <div class="absolute bottom-0 inset-x-0 h-16 bg-gradient-to-t from-blue-500/5 to-transparent pointer-events-none"></div>
        </div>
      </div>

    </div>

    <!-- Stats strip (poin 8) -->
    <div class="about-stats mt-16 rounded-2xl border border-white/8 bg-white/4 backdrop-blur-sm overflow-hidden">
      <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-y md:divide-y-0 divide-white/8">
        {stats.map(({ value, label, accent }) => (
          <div class="py-8 px-6 text-center group hover:bg-white/4 transition-colors duration-200">
            <p class={`text-4xl font-bold tabular-nums ${accent}`}>{value}</p>
            <p class="text-xs text-gray-500 mt-2 uppercase tracking-widest">{label}</p>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

<script>
  const targets = document.querySelectorAll<HTMLElement>('.about-label, .about-text, .about-terminal, .about-stats');

  const io = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        (entry.target as HTMLElement).classList.add('about--in');
        io.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  targets.forEach((el, i) => {
    (el as HTMLElement).style.transitionDelay = `${i * 0.1}s`;
    io.observe(el);
  });
</script>

<style>
  .terminal-cursor {
    display: inline-block;
    width: 8px;
    height: 1em;
    background: rgba(255, 255, 255, 0.75);
    animation: cur-blink 1s step-end infinite;
    vertical-align: text-bottom;
    margin-left: 1px;
  }

  @keyframes cur-blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  .about-label,
  .about-text,
  .about-terminal,
  .about-stats {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.75s ease, transform 0.75s ease;
  }

  .about--in {
    opacity: 1;
    transform: translateY(0);
  }
</style>
