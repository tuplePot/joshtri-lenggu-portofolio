---
import { Icon } from 'astro-icon/components';
import Heading from '@/components/ui/Heading.astro';
import Paragraph from '@/components/ui/Paragraph.astro';

interface I18nString {
  id: string;
  en: string;
}

interface KeyProject {
  title: I18nString | string;
  description: I18nString | string;
}

interface ApiWorkExperience {
  _id: string;
  role: I18nString | string;
  company: I18nString | string;
  companyUrl?: string;
  startDate: string;
  endDate?: string;
  current?: boolean;
  description: I18nString | string;
  keyProjects?: KeyProject[];
  tags: string[];
}

interface ApiEducation {
  _id: string;
  degree: I18nString | string;
  school: I18nString | string;
  startYear: number;
  endYear?: number;
  gpa?: string;
  description: I18nString | string;
}

const pickLang = (text: I18nString | string | undefined, lang: 'en' | 'id', fallback = ''): string => {
  if (!text) return fallback;
  if (typeof text === 'string') return text;
  return text[lang] || text[lang === 'en' ? 'id' : 'en'] || fallback;
};

function formatPeriod(startDate: string, endDate?: string): string {
  const start    = new Date(startDate);
  const startStr = start.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
  if (!endDate) return startStr;
  const end    = new Date(endDate);
  const endStr = end.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
  return `${startStr} – ${endStr}`;
}

function formatEduPeriod(startYear: number, endYear?: number): string {
  return endYear ? `${startYear} – ${endYear}` : `${startYear}`;
}

import { fetchApi } from '@/utils/api';

const [workData, eduData] = await Promise.all([
  fetchApi<ApiWorkExperience[]>('/api/work-experiences'),
  fetchApi<ApiEducation[]>('/api/educations'),
]);
const workExperience: ApiWorkExperience[] = workData ?? [];
const education: ApiEducation[] = eduData ?? [];

const codingSince   = 2020;
const currentYear   = new Date().getFullYear();
const yearsOfCoding = currentYear - codingSince;
---

<section id="experience" class="relative overflow-hidden py-24">

  <div class="relative z-10 max-w-6xl mx-auto px-6 sm:px-10">

    <!-- Header -->
    <div class="exp-header text-center mb-14">
      <span class="text-xs font-semibold tracking-widest text-blue-400 uppercase mb-3 block">
        <span class="i18n-en">Background</span>
        <span class="i18n-id">Latar Belakang</span>
      </span>
      <Heading level="h2" class="text-white mb-3">
        <span class="i18n-en">Experience &amp; Education</span>
        <span class="i18n-id">Pengalaman &amp; Pendidikan</span>
      </Heading>
      <Paragraph color="muted" class="max-w-lg mx-auto">
        <span class="i18n-en">{yearsOfCoding}+ years writing code — from college assignments to production systems.</span>
        <span class="i18n-id">{yearsOfCoding}+ tahun menulis kode — dari tugas kuliah hingga sistem produksi.</span>
      </Paragraph>
    </div>

    <!-- Two columns -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">

      <!-- LEFT — Work Experience -->
      <div class="exp-work">
        <div class="flex items-center gap-2 mb-8">
          <Icon name="lucide:briefcase" class="w-4 h-4 text-blue-400" />
          <h3 class="text-sm font-semibold text-white uppercase tracking-widest">
            <span class="i18n-en">Work</span>
            <span class="i18n-id">Pekerjaan</span>
          </h3>
        </div>

        <div class="relative">
          <div class="absolute left-[7px] top-2 bottom-2 w-px bg-white/10"></div>

          <div class="space-y-8">
            {workExperience.map((item) => (
              <div class="relative pl-8">
                <div class={`absolute left-0 top-1.5 w-3.5 h-3.5 rounded-full border-2 ${item.current ? 'bg-blue-500 border-blue-400' : 'bg-gray-700 border-gray-500'}`}></div>

                <div class="rounded-xl border border-white/8 bg-white/4 p-5 hover:border-white/15 transition-colors duration-200">
                  <div class="flex items-start justify-between gap-3 mb-1">
                    <h4 class="text-sm font-semibold text-white leading-snug">
                      <span class="i18n-en">{pickLang(item.role, 'en')}</span>
                      <span class="i18n-id">{pickLang(item.role, 'id')}</span>
                    </h4>
                    {item.current && (
                      <span class="shrink-0 flex items-center gap-1 text-xs text-green-400 bg-green-400/10 border border-green-400/20 px-2 py-0.5 rounded-full">
                        <span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse"></span>
                        <span class="i18n-en">Now</span>
                        <span class="i18n-id">Sekarang</span>
                      </span>
                    )}
                  </div>

                  <div class="flex items-center gap-2 mb-3">
                    {item.companyUrl && item.companyUrl !== '#' ? (
                      <a href={item.companyUrl} target="_blank" rel="noopener noreferrer"
                        class="text-xs text-blue-400 hover:text-blue-300 transition-colors">
                        <span class="i18n-en">{pickLang(item.company, 'en')}</span>
                        <span class="i18n-id">{pickLang(item.company, 'id')}</span>
                      </a>
                    ) : (
                      <span class="text-xs text-gray-400">
                        <span class="i18n-en">{pickLang(item.company, 'en')}</span>
                        <span class="i18n-id">{pickLang(item.company, 'id')}</span>
                      </span>
                    )}
                    <span class="text-white/20">·</span>
                    <span class="text-xs text-gray-500">
                      {item.current
                        ? <>{formatPeriod(item.startDate)} – <span class="i18n-en">Present</span><span class="i18n-id">Sekarang</span></>
                        : formatPeriod(item.startDate, item.endDate)}
                    </span>
                  </div>

                  <p class="text-xs text-gray-400 leading-relaxed mb-3">
                    <span class="i18n-en">{pickLang(item.description, 'en')}</span>
                    <span class="i18n-id">{pickLang(item.description, 'id')}</span>
                  </p>

                  {item.keyProjects && item.keyProjects.length > 0 && (
                    <div class="mb-4">
                      <p class="text-[10px] font-semibold text-white/40 uppercase tracking-widest mb-2">
                        <span class="i18n-en">Key Projects</span>
                        <span class="i18n-id">Proyek Utama</span>
                      </p>
                      <div class="space-y-2">
                        {item.keyProjects.map((kp) => (
                          <div class="flex gap-2">
                            <span class="mt-1.5 w-1 h-1 shrink-0 rounded-full bg-blue-400/60"></span>
                            <div>
                              <span class="text-xs text-white/80 font-medium">
                                <span class="i18n-en">{pickLang(kp.title, 'en')}</span>
                                <span class="i18n-id">{pickLang(kp.title, 'id')}</span>
                              </span>
                              {(typeof kp.description === 'string' ? kp.description : (kp.description?.en || kp.description?.id)) && (
                                <span class="text-xs text-gray-500">
                                  {' — '}
                                  <span class="i18n-en">{pickLang(kp.description, 'en')}</span>
                                  <span class="i18n-id">{pickLang(kp.description, 'id')}</span>
                                </span>
                              )}
                            </div>
                          </div>
                        ))}
                      </div>
                    </div>
                  )}

                  <div class="flex flex-wrap gap-1.5">
                    {(item.tags ?? []).map((tag) => (
                      <span class="text-xs px-2 py-0.5 rounded-full bg-white/5 border border-white/8 text-gray-400">
                        {tag}
                      </span>
                    ))}
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- RIGHT — Education -->
      <div class="exp-edu">
        <div class="flex items-center gap-2 mb-8">
          <Icon name="lucide:graduation-cap" class="w-4 h-4 text-yellow-400" />
          <h3 class="text-sm font-semibold text-white uppercase tracking-widest">
            <span class="i18n-en">Education</span>
            <span class="i18n-id">Pendidikan</span>
          </h3>
        </div>

        <div class="relative">
          <div class="absolute left-[7px] top-2 bottom-2 w-px bg-white/10"></div>

          <div class="space-y-8">
            {education.map((item) => (
              <div class="relative pl-8">
                <div class="absolute left-0 top-1.5 w-3.5 h-3.5 rounded-full border-2 bg-yellow-500/30 border-yellow-500/60"></div>

                <div class="rounded-xl border border-white/8 bg-white/4 p-5 hover:border-white/15 transition-colors duration-200">
                  <h4 class="text-sm font-semibold text-white mb-1">
                    <span class="i18n-en">{pickLang(item.degree, 'en')}</span>
                    <span class="i18n-id">{pickLang(item.degree, 'id')}</span>
                  </h4>

                  <div class="flex items-center gap-2 mb-3">
                    <span class="text-xs text-gray-400">
                      <span class="i18n-en">{pickLang(item.school, 'en')}</span>
                      <span class="i18n-id">{pickLang(item.school, 'id')}</span>
                    </span>
                    <span class="text-white/20">·</span>
                    <span class="text-xs text-gray-500">
                      {formatEduPeriod(item.startYear, item.endYear)}
                    </span>
                    {item.gpa && (
                      <>
                        <span class="text-white/20">·</span>
                        <span class="text-xs text-yellow-400/80">GPA {item.gpa}</span>
                      </>
                    )}
                  </div>

                  <p class="text-xs text-gray-400 leading-relaxed">
                    <span class="i18n-en">{pickLang(item.description, 'en')}</span>
                    <span class="i18n-id">{pickLang(item.description, 'id')}</span>
                  </p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  const targets = document.querySelectorAll<HTMLElement>(
    '#experience .exp-header, #experience .exp-work, #experience .exp-edu'
  );

  const io = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        (entry.target as HTMLElement).classList.add('exp--in');
        io.unobserve(entry.target);
      }
    });
  }, { threshold: 0.08 });

  targets.forEach((el, i) => {
    el.style.transitionDelay = `${i * 0.12}s`;
    io.observe(el);
  });
</script>

<style>
  .exp-header,
  .exp-work,
  .exp-edu {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.75s ease, transform 0.75s ease;
  }

  .exp--in {
    opacity: 1;
    transform: translateY(0);
  }
</style>
