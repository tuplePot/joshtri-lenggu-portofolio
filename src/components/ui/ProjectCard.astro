---
import { Icon } from 'astro-icon/components';
import { getFileUrl } from '@/utils/appwrite';
import AskAIButton from '@/components/ai/AskAIButton.astro';

interface ApiSkill {
  _id: string;
  name: string;
  icon: string;
  color: string;
}

export interface I18nString {
  id: string;
  en: string;
}

export interface Project {
  _id?: string;
  title: I18nString | string;
  description?: I18nString | string;
  skillIds?: ApiSkill[];
  thumbnailId?: string;
  link?: string;
  screenshots?: string[];
  projectYear?: number;
  type?: 'FRONTEND' | 'BACKEND' | 'FULLSTACK';
  githubRepoUrl?: string;
}

interface Props {
  project: Project;
}

const { project } = Astro.props;
const skills = project.skillIds ?? [];

const pickLang = (text: I18nString | string | undefined, lang: 'en' | 'id', fallback = ''): string => {
  if (!text) return fallback;
  if (typeof text === 'string') return text;
  return text[lang] || text[lang === 'en' ? 'id' : 'en'] || fallback;
};

const titleEn = pickLang(project.title, 'en', 'Untitled Project');
const titleId = pickLang(project.title, 'id', 'Untitled Project');
const descEn  = pickLang(project.description, 'en');
const descId  = pickLang(project.description, 'id');

const thumbnailUrl = project.thumbnailId ? getFileUrl(project.thumbnailId) : null;
const screenshotUrls = (project.screenshots ?? []).map(id => getFileUrl(id));
const allImages = [thumbnailUrl, ...screenshotUrls].filter((u): u is string => !!u);

const typeConfig: Record<string, { label: string; cls: string }> = {
  FRONTEND:  { label: 'Frontend',   cls: 'text-blue-400 bg-blue-400/10 border-blue-400/25'   },
  BACKEND:   { label: 'Backend',    cls: 'text-green-400 bg-green-400/10 border-green-400/25' },
  FULLSTACK: { label: 'Full-stack', cls: 'text-amber-400 bg-amber-400/10 border-amber-400/25' },
};
const typeInfo = project.type ? typeConfig[project.type] : null;
---

<article
  class="group flex flex-col rounded-2xl border border-white/10 bg-white/5 backdrop-blur-md overflow-hidden hover:border-blue-400/35 hover:bg-white/8 hover:shadow-[0_0_40px_rgba(59,130,246,0.12)] transition-all duration-300 cursor-pointer"
  data-gallery={JSON.stringify(allImages)}
  data-href={project._id ? `/projects/${project._id}` : undefined}
>
  <!-- Thumbnail / Gallery -->
  <div class="relative h-44 overflow-hidden bg-[#080810]">
    {allImages.length > 0 ? (
      <img
        data-gallery-img
        src={allImages[0]}
        alt={titleEn}
        class="w-full h-full object-cover object-top transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center">
        <div class="flex flex-col items-center gap-2 opacity-30">
          <Icon name="lucide:image" class="w-10 h-10 text-gray-500" />
        </div>
        <div class="absolute inset-0 opacity-10" style="background-image:linear-gradient(rgba(255,255,255,.06) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.06) 1px,transparent 1px);background-size:28px 28px"></div>
      </div>
    )}

    <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent"></div>

    <!-- Top badges row -->
    <div class="absolute top-3 left-3 right-3 flex items-center justify-between">
      {typeInfo && (
        <span class={`flex items-center gap-1 px-2 py-0.5 rounded-full border text-[10px] font-semibold tracking-wide ${typeInfo.cls}`}>
          {typeInfo.label}
        </span>
      )}
      <div class="flex gap-1.5 ml-auto">
        {project.githubRepoUrl && (
          <a
            href={project.githubRepoUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-1 px-2 py-0.5 rounded-full bg-black/60 backdrop-blur-sm border border-white/15 text-white/70 hover:text-white hover:border-white/40 text-[10px] transition-colors"
          >
            <Icon name="simple-icons:github" class="w-3 h-3" />
            Code
          </a>
        )}
        {project.link && project.link !== '#' && (
          <a
            href={project.link}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-1 px-2 py-0.5 rounded-full bg-black/60 backdrop-blur-sm border border-white/15 text-white/70 hover:text-white hover:border-blue-400/50 text-[10px] transition-colors"
          >
            <Icon name="lucide:external-link" class="w-3 h-3" />
            Live
          </a>
        )}
      </div>
    </div>

    <!-- Year + screenshot dots row -->
    <div class="absolute bottom-3 left-3 right-3 flex items-center justify-between">
      {project.projectYear && (
        <span class="px-2 py-0.5 rounded-full bg-black/60 backdrop-blur-sm border border-white/15 text-white/60 text-[10px] font-mono">
          {project.projectYear}
        </span>
      )}
      {allImages.length > 1 && (
        <div data-gallery-dots class="flex items-center gap-1 ml-auto"></div>
      )}
    </div>
  </div>

  <!-- Content -->
  <div class="flex flex-col flex-1 p-5 gap-3">
    <div class="flex items-start justify-between gap-2">
      <h3 class="text-sm font-semibold text-white leading-snug line-clamp-2 group-hover:text-blue-100 transition-colors">
        <span class="i18n-en">{titleEn}</span>
        <span class="i18n-id">{titleId}</span>
      </h3>
      <AskAIButton
        iconOnly
        class="shrink-0 -mt-0.5"
        question={`Explain the project "${titleEn}" — what is it and what technologies does it use?`}
        labelEn={`Ask AI about ${titleEn}`}
        labelId="Tanya AI soal proyek ini"
      />
    </div>

    <p class="text-xs text-gray-400 leading-relaxed line-clamp-3 flex-1">
      <span class="i18n-en">{descEn || '—'}</span>
      <span class="i18n-id">{descId || '—'}</span>
    </p>

    {skills.length > 0 && (
      <div class="flex flex-wrap gap-1.5 pt-1 border-t border-white/5">
        {skills.slice(0, 4).map((skill) => (
          <span class="flex items-center gap-1 px-2 py-0.5 rounded-full bg-white/5 border border-white/10 text-xs text-gray-300 hover:border-white/20 transition-colors">
            <Icon name={skill.icon} class="w-3 h-3" style={`color: ${skill.color}`} />
            {skill.name}
          </span>
        ))}
        {skills.length > 4 && (
          <span class="px-2 py-0.5 rounded-full bg-white/5 border border-white/10 text-xs text-gray-500">
            +{skills.length - 4}
          </span>
        )}
      </div>
    )}
  </div>
</article>

<script>
  // Navigate to detail page on card click (not on link/button clicks)
  document.querySelectorAll<HTMLElement>('[data-href]').forEach(card => {
    card.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('a, button')) return;
      const href = card.dataset.href;
      if (href) window.location.href = href;
    });
  });

  document.querySelectorAll<HTMLElement>('[data-gallery]').forEach(card => {
    const images: string[] = JSON.parse(card.dataset.gallery ?? '[]');
    if (images.length <= 1) return;

    const imgEl   = card.querySelector<HTMLImageElement>('[data-gallery-img]');
    const dotsEl  = card.querySelector<HTMLElement>('[data-gallery-dots]');
    if (!imgEl || !dotsEl) return;

    let current = 0;

    const dots = images.map((_, i) => {
      const btn = document.createElement('button');
      btn.setAttribute('aria-label', `Screenshot ${i + 1}`);
      btn.className = `h-1.5 rounded-full transition-all duration-300 ${i === 0 ? 'w-3 bg-white' : 'w-1.5 bg-white/40'}`;
      btn.addEventListener('click', (e) => { e.preventDefault(); goTo(i); });
      dotsEl.appendChild(btn);
      return btn;
    });

    function goTo(idx: number) {
      current = idx;
      imgEl!.src = images[idx];
      dots.forEach((d, i) => {
        d.className = `h-1.5 rounded-full transition-all duration-300 ${i === idx ? 'w-3 bg-white' : 'w-1.5 bg-white/40'}`;
      });
    }

    setInterval(() => goTo((current + 1) % images.length), 3500);
  });
</script>
